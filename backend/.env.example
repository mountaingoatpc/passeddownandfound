DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=atticory
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSLMODE=prefer

JWT_SECRET=change-me-in-production

PORT=8091
# API service port (Railway injects PORT). Do not reuse for ai_service — use AI_SERVICE_PORT below.
API_HOST=0.0.0.0
API_RELOAD=true
FRONTEND_URL=http://localhost:5173

AI_SERVICE_URL=http://localhost:8001
AI_SERVICE_OPENAI_API_KEY=
AI_SERVICE_MODEL=gpt-5.5
AI_SERVICE_DESCRIPTION_MODEL=gpt-5.4-mini
AI_SERVICE_PORT=8001

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
S3_KEY_PREFIX=images
# Optional CloudFront or custom public base URL, e.g. https://d111111abcdef8.cloudfront.net
S3_PUBLIC_BASE_URL=
# Leave empty if your bucket uses a bucket policy instead of object ACLs
S3_ACL=
