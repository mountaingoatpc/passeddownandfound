# Copy to .env.local for local dev, .env.dev for Railway dev (main), or .env.prod for Railway prod (release).
# Never commit .env.local, .env.dev, or .env.prod — they are gitignored.
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=atticory
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSLMODE=prefer

JWT_SECRET=change-me-in-production

PORT=8091
# API service port (Railway injects PORT). Do not reuse for ai_service — use AI_SERVICE_PORT below.
API_HOST=0.0.0.0
API_RELOAD=true
FRONTEND_URL=http://localhost:5173

AI_SERVICE_URL=http://localhost:8001
AI_SERVICE_OPENAI_API_KEY=
AI_SERVICE_MODEL=gpt-5.5
AI_SERVICE_DESCRIPTION_MODEL=gpt-5.4-mini
AI_SERVICE_PORT=8001
